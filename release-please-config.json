          "hidden": false
        },
        {
          "type": "perf",
          "section": "⚡ Performance Improvements",
          "hidden": false
        },
        {
          "type": "refactor",
          "section": "🔧 Refactoring",
          "hidden": false
        },
        {
          "type": "docs",
          "section": "📚 Documentation",
          "hidden": false
        },
        {
          "type": "test",
          "section": "🧪 Tests",
          "hidden": false
        },
        {
          "type": "style",
          "section": "🎨 Code Style",
          "hidden": true
        },
        {
          "type": "chore",
          "section": "🧹 Chores & Maintenance",
          "hidden": true
        },
        {
          "type": "build",
          "section": "🏗️ Build System",
          "hidden": true
        },
        {
          "type": "ci",
          "section": "🔄 CI/CD",
          "hidden": true
        },
        {
          "type": "revert",
          "section": "⏪ Reverts",
          "hidden": false
        }
      ]
